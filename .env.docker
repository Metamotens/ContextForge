# ContextForge metaserver — do not commit (.env.docker)
# Used by: docker compose --env-file .env.docker (see docker-compose.yml)

NODE_ENV=production
LOG_LEVEL=info
MCP_PORT=3030
API_PORT=3000

# Internal Docker network (container names; compose also overrides these for api/mcp)
POSTGRES_HOST=contextforge-postgres
POSTGRES_PORT=5432
POSTGRES_DB=contextforge
POSTGRES_USER=contextforge
POSTGRES_PASSWORD=contextforge
DATABASE_URL=postgresql://contextforge:contextforge@contextforge-postgres:5432/contextforge

EMBEDDING_PROVIDER=ollama
OLLAMA_URL=http://contextforge-ollama:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_VECTOR_SIZE=768
TOPK_DEFAULT=3

OLLAMA_CHAT_MODEL=gemma3:4b
SUMMARY_MAX_OUTPUT_TOKENS=512
SUMMARY_LLM_TIMEOUT_MS=60000
SUMMARY_TURN_THRESHOLD=8
SUMMARY_TOKEN_THRESHOLD=4000

# Browser-facing URLs (IP/host seen by your PC's browser — rebuild dashboard after changes)
# Dashboard proxies /api on :8080 — only forward port 8080 for internet access.
# Uncomment CORS_ORIGINS only if you expose :3000 to browsers on a different origin.
# CORS_ORIGINS=http://your-public-ip:8080
