# ============================================================
# ContextForge
# ============================================================

NODE_ENV=production
LOG_LEVEL=info

# ============================================================
# API (futuro)
# ============================================================

API_PORT=3000
MCP_PORT=3030

# ============================================================
# PostgreSQL + pgvector
# ============================================================

POSTGRES_HOST=192.168.68.71
POSTGRES_PORT=5432

POSTGRES_DB=contextforge
POSTGRES_USER=contextforge
POSTGRES_PASSWORD=contextforge

# Connection string opcional
DATABASE_URL=postgresql://contextforge:contextforge@192.168.68.71:5432/contextforge

# ============================================================
# Embeddings
# ============================================================

EMBEDDING_PROVIDER=ollama

OLLAMA_URL=http://192.168.68.71:11434

OLLAMA_EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_VECTOR_SIZE=768

TOPK_DEFAULT=3

# ============================================================
# LLM Summaries
# ============================================================

OLLAMA_CHAT_MODEL=gemma3:4b

SUMMARY_MAX_OUTPUT_TOKENS=512
SUMMARY_LLM_TIMEOUT_MS=60000

# ============================================================
# Summary thresholds
# ============================================================

SUMMARY_TURN_THRESHOLD=8
SUMMARY_TOKEN_THRESHOLD=4000