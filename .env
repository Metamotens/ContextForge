# ============================================================
# ContextForge
# ============================================================

NODE_ENV=production
LOG_LEVEL=info

# ============================================================
# API (futuro)
# ============================================================

API_PORT=3000

# ============================================================
# PostgreSQL + pgvector
# ============================================================

POSTGRES_HOST=contextforge-postgres
POSTGRES_PORT=5432

POSTGRES_DB=contextforge
POSTGRES_USER=contextforge
POSTGRES_PASSWORD=contextforge_dev_password

# Connection string opcional
DATABASE_URL=postgresql://contextforge:contextforge_dev_password@contextforge-postgres:5432/contextforge

# ============================================================
# Embeddings
# ============================================================

EMBEDDING_PROVIDER=ollama

OLLAMA_URL=http://contextforge-ollama:11434

OLLAMA_EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_VECTOR_SIZE=768

TOPK_DEFAULT=3

# ============================================================
# LLM Summaries
# ============================================================

OLLAMA_CHAT_MODEL=qwen3:4b

SUMMARY_MAX_OUTPUT_TOKENS=512
SUMMARY_LLM_TIMEOUT_MS=60000

# ============================================================
# Summary thresholds
# ============================================================

SUMMARY_TURN_THRESHOLD=8
SUMMARY_TOKEN_THRESHOLD=4000