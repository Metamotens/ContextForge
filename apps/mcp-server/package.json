{
  "name": "@contextforge/mcp-server",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.16.1",
  "description": "ContextForge MCP server (NestJS)",
  "imports": {
    "@common/*": "./src/common/*",
    "@persistence/*": "./src/persistence/*",
    "@retrieval/*": "./src/retrieval/*",
    "@enrichment/*": "./src/enrichment/*",
    "@mcp/*": "./src/mcp/*",
    "@config/*": "./src/config/*",
    "@app/*": "./src/*"
  },
  "scripts": {
    "start": "node dist/main.js",
    "build": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
    "start:dev": "node -r tsconfig-paths/register -r ts-node/register src/main.ts",
    "db:smoke": "node --env-file=../../.env -r tsconfig-paths/register -r ts-node/register src/scripts/smoke-test.ts",
    "db:smoke-summary": "node --env-file=../../.env -r tsconfig-paths/register -r ts-node/register src/scripts/smoke-summary.ts",
    "validate:e2e": "node --env-file=../../.env -r tsconfig-paths/register -r ts-node/register src/scripts/smoke-summary.ts",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@nestjs/common": "^11.1.26",
    "@nestjs/core": "^11.1.26",
    "@rekog/mcp-nest": "^1.9.10",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/node": "^22.19.20",
    "@types/pg": "^8.11.10",
    "prettier": "^3.8.4",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.17",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  }
}
