# Copy to ContextForge/.env.docker on the metaserver (do not commit .env.docker).
# Used by: docker compose (see docker-compose.yml at repo root)

NODE_ENV=production
LOG_LEVEL=info
MCP_PORT=3030

# Container names on network "contextforge" (use these, not compose service names)
POSTGRES_HOST=contextforge-postgres
POSTGRES_PORT=5432
POSTGRES_DB=contextforge
POSTGRES_USER=contextforge
POSTGRES_PASSWORD=contextforge
DATABASE_URL=postgresql://contextforge:contextforge@contextforge-postgres:5432/contextforge

EMBEDDING_PROVIDER=ollama
OLLAMA_URL=http://contextforge-ollama:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_VECTOR_SIZE=768
TOPK_DEFAULT=3

OLLAMA_CHAT_MODEL=gemma3:4b
SUMMARY_MAX_OUTPUT_TOKENS=512
SUMMARY_LLM_TIMEOUT_MS=60000
SUMMARY_TURN_THRESHOLD=8
SUMMARY_TOKEN_THRESHOLD=4000
