{
  "name": "@contextforge/root",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.16.1",
  "scripts": {
    "build": "tsc -b",
    "build:core": "pnpm --filter @contextforge/core build",
    "build:shared": "pnpm --filter @contextforge/shared build",
    "build:api": "pnpm --filter @contextforge/api build",
    "build:mcp": "pnpm --filter @contextforge/mcp-server build",
    "clean": "tsc -b --clean",
    "dev:api": "pnpm --filter @contextforge/api start:dev",
    "dev:dashboard": "pnpm --filter @contextforge/dashboard start",
    "dev:mcp": "pnpm --filter @contextforge/mcp-server start:dev",
    "build:dashboard": "pnpm --filter @contextforge/dashboard build",
    "db:init": "pnpm --filter @contextforge/core db:init",
    "db:smoke": "pnpm --filter @contextforge/mcp-server db:smoke",
    "test:e2e": "pnpm --filter @contextforge/mcp-server test:e2e",
    "format": "prettier --write \"**/*.{ts,json,md}\""
  },
  "devDependencies": {
    "prettier": "^3.8.4",
    "typescript": "^5.9.3"
  }
}
